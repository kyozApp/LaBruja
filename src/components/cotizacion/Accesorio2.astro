---
import accesorios2 from "@data/accesorio.json";
---

<div>
    <p>accesorio2</p>
    <select id="accesorio2Select">
        <option value="">Selecciona una accesorio2</option>
        {
            accesorios2.map((p) => (
                <option
                    value={p.id}
                    data-nombre={p.nombre}
                    data-precio={p.precio}
                    data-stock={p.stockTotal}
                >
                    {p.nombre}
                </option>
            ))
        }
    </select>
</div>

<p>El id es: <span id="accesorio2_id">Ninguno</span></p>
<p>El nombre es: <span id="accesorio2_nombre">Ninguno</span></p>
<p>El precio es: S/.<span id="accesorio2_precio">0</span></p>
<p>El stock es: <span id="accesorio2_stock">0</span></p>

<script type="module">
    document.addEventListener("DOMContentLoaded", () => {
        const accesorio2 = document.getElementById("accesorio2Select");
        const accesorio2Id = document.getElementById("accesorio2_id");
        const accesorio2Nombre = document.getElementById("accesorio2_nombre");
        const accesorio2Precio = document.getElementById("accesorio2_precio");
        const accesorio2Stock = document.getElementById("accesorio2_stock");

        if (
            !accesorio2 ||
            !accesorio2Id ||
            !accesorio2Nombre ||
            !accesorio2Precio ||
            !accesorio2Stock
        )
            return;

        accesorio2.addEventListener("change", (event) => {
            const accesorio2_id = event.target.value;
            accesorio2Id.textContent = accesorio2_id || "Ninguno";

            const selectedOption =
                event.target.options[event.target.selectedIndex];
            const accesorio2_nombre =
                selectedOption.getAttribute("data-nombre") || "Ninguno";
            const accesorio2_precio =
                selectedOption.getAttribute("data-precio") || "0";
            const accesorio2_stock =
                selectedOption.getAttribute("data-stock") || "0";

            accesorio2Nombre.textContent = accesorio2_nombre;
            accesorio2Precio.textContent =
                parseFloat(accesorio2_precio).toFixed(2);
            accesorio2Stock.textContent = accesorio2_stock;
        });
        accesorio2Nombre.textContent = "Ninguno";
        accesorio2Precio.textContent = "0";
        accesorio2Stock.textContent = "0";
    });
</script>
