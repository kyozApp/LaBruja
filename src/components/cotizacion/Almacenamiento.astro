---
import almacenamientos from "@data/almacenamiento.json";
---

<div>
    <p>almacenamiento</p>
    <select id="almacenamientoSelect">
        <option value="">Selecciona una almacenamiento</option>
        {
            almacenamientos.map((p) => (
                <option
                    value={p.id}
                    data-nombre={p.nombre}
                    data-precio={p.precio}
                    data-stock={p.stockTotal}
                >
                    {p.nombre}
                </option>
            ))
        }
    </select>
</div>

<p>El id es: <span id="almacenamiento_id">Ninguno</span></p>
<p>El nombre es: <span id="almacenamiento_nombre">Ninguno</span></p>
<p>El precio es: <span id="almacenamiento_precio">Ninguno</span></p>
<p>El stock es: <span id="almacenamiento_stock">Ninguno</span></p>

<script type="module">
    document.addEventListener("DOMContentLoaded", () => {
        const almacenamiento = document.getElementById("almacenamientoSelect");
        const almacenamientoId = document.getElementById("almacenamiento_id");
        const almacenamientoNombre = document.getElementById("almacenamiento_nombre");
        const almacenamientoPrecio = document.getElementById("almacenamiento_precio");
        const almacenamientoStock = document.getElementById("almacenamiento_stock");

        if (!almacenamiento || !almacenamientoId || !almacenamientoNombre || !almacenamientoPrecio || !almacenamientoStock) return;

        almacenamiento.addEventListener("change", (event) => {
            const almacenamiento_id = event.target.value;
            almacenamientoId.textContent = almacenamiento_id || "Ninguno";

            const selectedOption =
                event.target.options[event.target.selectedIndex];
            const almacenamiento_nombre =
                selectedOption.getAttribute("data-nombre") || "Ninguno";
            const almacenamiento_precio =
                selectedOption.getAttribute("data-precio") || "Ninguno";
            const almacenamiento_stock =
                selectedOption.getAttribute("data-stock") || "Ninguno";

            almacenamientoNombre.textContent = almacenamiento_nombre;
            almacenamientoPrecio.textContent = `$${parseFloat(almacenamiento_precio).toFixed(2)}`;
            almacenamientoStock.textContent = almacenamiento_stock;
        });
    });
</script>
