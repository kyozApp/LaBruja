---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<div class="contenedor-titulo">
    <p>{title}</p>
</div>

<style>
    .contenedor-titulo {
        font-size: 1.8rem;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100px;
        width: 70%;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
    }
</style>
